{
  "name": "ai-prompt-helper",
  "version": "1.0.0",
  "description": "AI提示词助手 - AI Prompt Helper",
  "main": "main.js",
  "scripts": {
    "start": "electron . --no-sandbox",
    "dev": "electron . --no-sandbox --dev",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build": "electron-builder --win --mac"
  },
  "build": {
    "appId": "com.ai-prompt-helper.app",
    "productName": "AI提示词助手",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "config/**/*",
      "assets/**/*",
      "node_modules/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/H.jpg"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/H.jpg"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^34.5.1"
  }
}
