{
  "name": "ai-prompt-helper",
  "version": "1.0.0",
  "description": "AI提示词助手 - AI Prompt Helper",
  "main": "main.js",
  "scripts": {
    "start": "electron . --no-sandbox",
    "dev": "electron . --no-sandbox --dev",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build": "electron-builder --win --mac"
  },
  "build": {
    "appId": "com.ai-prompt-helper.app",
    "productName": "AI提示词助手",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "logger.js",
      "renderer/**/*",
      "config/**/*",
      "assets/**/*",
      "node_modules/**/*",
      "!logs/**",
      "!tmp_userdata/**",
      "!.trae/**",
      "!.idea/**",
      "!_patch*.js",
      "!_b64*.txt",
      "!_test_*.txt",
      "!docs/**",
      "!*.md",
      "!package-lock.json"
    ],
    "asar": true,
    "compression": "maximum",
    "win": {
      "target": [
        "portable",
        "nsis"
      ],
      "icon": "assets/H.ico"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": ["x64", "arm64"]
        }
      ],
      "icon": "assets/H.ico",
      "category": "public.app-category.utilities",
      "hardenedRuntime": true,
      "gatekeeperAssess": false
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "assets/H.ico",
      "uninstallerIcon": "assets/H.ico",
      "installerHeaderIcon": "assets/H.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "AI提示词助手",
      "deleteAppDataOnUninstall": true
    }
  },
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^34.5.1",
    "electron-builder": "^26.15.3"
  }
}
